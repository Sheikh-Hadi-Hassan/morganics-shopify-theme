{% liquid
  assign row_count_class = 'ingredient-library--rows-' | append: section.settings.max_rows_desktop
  assign mobile_row_class = ''
  unless section.settings.enable_third_row_mobile
    assign mobile_row_class = ' ingredient-library--mobile-two-rows'
  endunless
%}

{% capture block_row_1 %}
  {% for block in section.blocks %}
    {% liquid
      assign product = block.settings.product
      assign modulo = forloop.index0 | modulo: 3
      assign should_render = false
      if block.settings.row == 'row_1'
        assign should_render = true
      elsif block.settings.row == 'auto' and modulo == 0
        assign should_render = true
      endif
    %}
    {% if product != blank and should_render %}
      {% render 'morganics-ingredient-marquee-card', ingredient_product: product, title_override: block.settings.title_override, category_override: block.settings.category_override, image_override: block.settings.image_override, alt_override: block.settings.alt_override, block_attributes: block.shopify_attributes %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture block_row_1_hidden %}
  {% for block in section.blocks %}
    {% liquid
      assign product = block.settings.product
      assign modulo = forloop.index0 | modulo: 3
      assign should_render = false
      if block.settings.row == 'row_1'
        assign should_render = true
      elsif block.settings.row == 'auto' and modulo == 0
        assign should_render = true
      endif
    %}
    {% if product != blank and should_render %}
      {% render 'morganics-ingredient-marquee-card', ingredient_product: product, title_override: block.settings.title_override, category_override: block.settings.category_override, image_override: block.settings.image_override, alt_override: block.settings.alt_override, aria_hidden: true %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture block_row_2 %}
  {% for block in section.blocks %}
    {% liquid
      assign product = block.settings.product
      assign modulo = forloop.index0 | modulo: 3
      assign should_render = false
      if block.settings.row == 'row_2'
        assign should_render = true
      elsif block.settings.row == 'auto' and modulo == 1
        assign should_render = true
      endif
    %}
    {% if product != blank and should_render %}
      {% render 'morganics-ingredient-marquee-card', ingredient_product: product, title_override: block.settings.title_override, category_override: block.settings.category_override, image_override: block.settings.image_override, alt_override: block.settings.alt_override, block_attributes: block.shopify_attributes %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture block_row_2_hidden %}
  {% for block in section.blocks %}
    {% liquid
      assign product = block.settings.product
      assign modulo = forloop.index0 | modulo: 3
      assign should_render = false
      if block.settings.row == 'row_2'
        assign should_render = true
      elsif block.settings.row == 'auto' and modulo == 1
        assign should_render = true
      endif
    %}
    {% if product != blank and should_render %}
      {% render 'morganics-ingredient-marquee-card', ingredient_product: product, title_override: block.settings.title_override, category_override: block.settings.category_override, image_override: block.settings.image_override, alt_override: block.settings.alt_override, aria_hidden: true %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture block_row_3 %}
  {% for block in section.blocks %}
    {% liquid
      assign product = block.settings.product
      assign modulo = forloop.index0 | modulo: 3
      assign should_render = false
      if block.settings.row == 'row_3'
        assign should_render = true
      elsif block.settings.row == 'auto' and modulo == 2
        assign should_render = true
      endif
    %}
    {% if product != blank and should_render %}
      {% render 'morganics-ingredient-marquee-card', ingredient_product: product, title_override: block.settings.title_override, category_override: block.settings.category_override, image_override: block.settings.image_override, alt_override: block.settings.alt_override, block_attributes: block.shopify_attributes %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture block_row_3_hidden %}
  {% for block in section.blocks %}
    {% liquid
      assign product = block.settings.product
      assign modulo = forloop.index0 | modulo: 3
      assign should_render = false
      if block.settings.row == 'row_3'
        assign should_render = true
      elsif block.settings.row == 'auto' and modulo == 2
        assign should_render = true
      endif
    %}
    {% if product != blank and should_render %}
      {% render 'morganics-ingredient-marquee-card', ingredient_product: product, title_override: block.settings.title_override, category_override: block.settings.category_override, image_override: block.settings.image_override, alt_override: block.settings.alt_override, aria_hidden: true %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture block_all %}
  {% for block in section.blocks %}
    {% if block.settings.product != blank %}
      {% render 'morganics-ingredient-marquee-card', ingredient_product: block.settings.product, title_override: block.settings.title_override, category_override: block.settings.category_override, image_override: block.settings.image_override, alt_override: block.settings.alt_override, block_attributes: block.shopify_attributes %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture block_all_hidden %}
  {% for block in section.blocks %}
    {% if block.settings.product != blank %}
      {% render 'morganics-ingredient-marquee-card', ingredient_product: block.settings.product, title_override: block.settings.title_override, category_override: block.settings.category_override, image_override: block.settings.image_override, alt_override: block.settings.alt_override, aria_hidden: true %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture collection_cards %}
  {% for product in collections.all.products limit: 24 %}
    {% render 'morganics-ingredient-marquee-card', ingredient_product: product %}
  {% endfor %}
{% endcapture %}

{% capture collection_cards_hidden %}
  {% for product in collections.all.products limit: 24 %}
    {% render 'morganics-ingredient-marquee-card', ingredient_product: product, aria_hidden: true %}
  {% endfor %}
{% endcapture %}

{% liquid
  assign row_1_cards = block_row_1
  assign row_1_hidden = block_row_1_hidden
  assign row_2_cards = block_row_2
  assign row_2_hidden = block_row_2_hidden
  assign row_3_cards = block_row_3
  assign row_3_hidden = block_row_3_hidden

  if section.blocks.size > 0
    assign row_1_check = row_1_cards | strip
    assign row_2_check = row_2_cards | strip
    assign row_3_check = row_3_cards | strip
    if row_1_check == ''
      assign row_1_cards = block_all
      assign row_1_hidden = block_all_hidden
    endif
    if row_2_check == ''
      assign row_2_cards = block_all
      assign row_2_hidden = block_all_hidden
    endif
    if row_3_check == ''
      assign row_3_cards = block_all
      assign row_3_hidden = block_all_hidden
    endif
  else
    assign row_1_cards = collection_cards
    assign row_1_hidden = collection_cards_hidden
    assign row_2_cards = collection_cards
    assign row_2_hidden = collection_cards_hidden
    assign row_3_cards = collection_cards
    assign row_3_hidden = collection_cards_hidden
  endif

  assign stat_count = section.blocks.size
  if stat_count == 0
    assign stat_count = collections.all.products_count
  endif
%}

<section
  class="morganics-ingredient-library home-ingredient-showcase ingredient-library {{ row_count_class }}{{ mobile_row_class }}{% if section.settings.pause_on_hover %} ingredient-library--pause-hover{% endif %}{% if section.settings.enable_reduced_motion %} ingredient-library--reduced-motion{% endif %}"
  id="shopify-section-{{ section.id }}-ingredient-library"
  data-journey-id="ingredients-linked"
  aria-label="{{ section.settings.aria_label | escape }}"
  style="--ingredient-bg: {{ section.settings.background_color }}; --row-1-speed: {{ section.settings.row_1_speed }}s; --row-2-speed: {{ section.settings.row_2_speed }}s; --row-3-speed: {{ section.settings.row_3_speed }}s;"
>
  {% if section.settings.enable_radial_glows %}
    <div class="ingredient-library-glows" aria-hidden="true"></div>
  {% endif %}
  {% if section.settings.enable_grid_overlay %}
    <div class="ingredient-library-grid" aria-hidden="true"></div>
  {% endif %}

  <div class="ingredient-hero">
    <span class="ingredient-kicker">{{ section.settings.kicker }}</span>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    {% if section.settings.show_stats %}
      <span class="ingredient-count">{{ stat_count }} linked products</span>
    {% endif %}
  </div>

  <div class="ingredient-marquee-section" aria-label="Morganics product ingredients">
    <div class="ingredient-marquees">
      {% if row_1_cards != blank %}
        <div class="ingredient-row ingredient-row--1">
          <div class="ingredient-marquee-track">
            <div class="ingredient-marquee-group">{{ row_1_cards }}</div>
            <div class="ingredient-marquee-group" aria-hidden="true">{{ row_1_hidden }}</div>
          </div>
        </div>
      {% endif %}

      {% if row_2_cards != blank %}
        <div class="ingredient-row ingredient-row--2 ingredient-row--reverse">
          <div class="ingredient-marquee-track">
            <div class="ingredient-marquee-group">{{ row_2_cards }}</div>
            <div class="ingredient-marquee-group" aria-hidden="true">{{ row_2_hidden }}</div>
          </div>
        </div>
      {% endif %}

      {% if row_3_cards != blank %}
        <div class="ingredient-row ingredient-row--3">
          <div class="ingredient-marquee-track">
            <div class="ingredient-marquee-group">{{ row_3_cards }}</div>
            <div class="ingredient-marquee-group" aria-hidden="true">{{ row_3_hidden }}</div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredient carousel",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "Morganics ingredient product library" },
    { "type": "text", "id": "kicker", "label": "Kicker text", "default": "Morganics Ingredient Library" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ingredients linked to real products" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Click any card to open its product page - with price, usage, and easy ordering." },
    { "type": "checkbox", "id": "show_stats", "label": "Show linked product count", "default": true },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#050706" },
    { "type": "checkbox", "id": "enable_grid_overlay", "label": "Enable grid overlay", "default": true },
    { "type": "checkbox", "id": "enable_radial_glows", "label": "Enable radial glows", "default": true },
    { "type": "range", "id": "row_1_speed", "label": "Row 1 speed", "min": 24, "max": 90, "step": 1, "unit": "s", "default": 45 },
    { "type": "range", "id": "row_2_speed", "label": "Row 2 speed", "min": 24, "max": 90, "step": 1, "unit": "s", "default": 55 },
    { "type": "range", "id": "row_3_speed", "label": "Row 3 speed", "min": 24, "max": 90, "step": 1, "unit": "s", "default": 50 },
    { "type": "checkbox", "id": "enable_third_row_mobile", "label": "Enable third row on mobile", "default": false },
    { "type": "checkbox", "id": "pause_on_hover", "label": "Pause on hover", "default": true },
    { "type": "checkbox", "id": "enable_reduced_motion", "label": "Enable reduced motion support", "default": true },
    {
      "type": "select",
      "id": "max_rows_desktop",
      "label": "Max visible rows desktop",
      "default": "3",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient card",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "title_override", "label": "Custom ingredient title override" },
        { "type": "text", "id": "category_override", "label": "Category label override" },
        { "type": "image_picker", "id": "image_override", "label": "Direct ingredient image override" },
        { "type": "text", "id": "alt_override", "label": "Alt text override" },
        {
          "type": "select",
          "id": "row",
          "label": "Row assignment",
          "default": "auto",
          "options": [
            { "value": "auto", "label": "Auto" },
            { "value": "row_1", "label": "Row 1" },
            { "value": "row_2", "label": "Row 2" },
            { "value": "row_3", "label": "Row 3" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [
    {
      "name": "Morganics ingredient carousel"
    }
  ]
}
{% endschema %}
