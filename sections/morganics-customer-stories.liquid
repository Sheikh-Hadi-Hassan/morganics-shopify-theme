<section class="ritual-film-section" id="story" data-journey-id="customer-stories" aria-label="{{ section.settings.aria_label | escape }}" data-story-carousel>
  <div class="ritual-film-glow" aria-hidden="true"></div>
  <div class="ritual-film-shell">
    <div class="ritual-film-head reveal">
      <span class="ritual-film-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    <div class="ritual-film-carousel" aria-live="polite">
      <button class="ritual-film-arrow ritual-film-arrow--prev" type="button" data-carousel-prev aria-label="Previous customer story">‹</button>
      <div class="ritual-film-track">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% assign image_file = block.settings.image_asset | default: 'morganics/review-images/ayesha-kitchen.jpg' %}
            <article class="ritual-film-card{% if forloop.first %} is-active{% endif %}" data-carousel-slide {{ block.shopify_attributes }}>
              <img src="{{ image_file | asset_url }}" alt="{{ block.settings.name | escape }}" width="520" height="640" loading="lazy">
              <div>
                <small>{{ block.settings.context }}</small>
                <h3>{{ block.settings.name }}</h3>
                <p>{{ block.settings.quote }}</p>
              </div>
            </article>
          {% endfor %}
        {% else %}
          <article class="ritual-film-card is-active" data-carousel-slide><img src="{{ 'morganics/review-images/ayesha-kitchen.jpg' | asset_url }}" alt="Ayesha kitchen routine" width="520" height="640" loading="lazy"><div><small>Kitchen routine</small><h3>Ayesha</h3><p>Morganics fits into our daily home routine with simple, useful pantry staples.</p></div></article>
          <article class="ritual-film-card" data-carousel-slide><img src="{{ 'morganics/review-images/ali-athlete.jpg' | asset_url }}" alt="Ali active lifestyle" width="520" height="640" loading="lazy"><div><small>Active lifestyle</small><h3>Ali</h3><p>Dates, nuts and seeds keep the snack box cleaner without making the routine complicated.</p></div></article>
          <article class="ritual-film-card" data-carousel-slide><img src="{{ 'morganics/review-images/dr-hira-nutritionist.jpg' | asset_url }}" alt="Dr Hira nutrition guidance" width="520" height="640" loading="lazy"><div><small>Nutrition guidance</small><h3>Dr. Hira</h3><p>Simple ingredients, clear labels and practical serving ideas make daily choices easier.</p></div></article>
        {% endif %}
      </div>
      <button class="ritual-film-arrow ritual-film-arrow--next" type="button" data-carousel-next aria-label="Next customer story">›</button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Morganics stories",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "Morganics customer ritual stories" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer Stories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real routines. Real Morganics." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Daily wellness, family snacks and clean energy through products people actually use." }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Ayesha" },
        { "type": "text", "id": "context", "label": "Context", "default": "Kitchen routine" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Morganics fits into our daily home routine with simple, useful pantry staples." },
        { "type": "text", "id": "image_asset", "label": "Image asset", "default": "morganics/review-images/ayesha-kitchen.jpg" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Morganics customer stories",
      "blocks": [
        { "type": "story", "settings": { "name": "Ayesha", "context": "Kitchen routine", "image_asset": "morganics/review-images/ayesha-kitchen.jpg" } },
        { "type": "story", "settings": { "name": "Ali", "context": "Active lifestyle", "image_asset": "morganics/review-images/ali-athlete.jpg" } },
        { "type": "story", "settings": { "name": "Dr. Hira", "context": "Nutrition guidance", "image_asset": "morganics/review-images/dr-hira-nutritionist.jpg" } }
      ]
    }
  ]
}
{% endschema %}
