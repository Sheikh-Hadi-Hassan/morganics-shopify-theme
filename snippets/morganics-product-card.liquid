{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign secondary_image = blank
  if product.images.size > 1
    for image in product.images
      if image.id != product.featured_image.id
        assign secondary_image = image
        break
      endif
    endfor
  endif
  assign product_tags_filter = product.tags | join: ' '
  capture product_collections_filter
    for product_collection in product.collections
      echo product_collection.handle
      echo ' '
      echo product_collection.title
      echo ' '
    endfor
  endcapture
  capture product_variant_filter
    for variant in product.variants
      echo variant.title
      echo ' '
      echo variant.sku
      echo ' '
    endfor
  endcapture
  assign product_size_filter = product_variant_filter | append: ' ' | append: product_tags_filter
%}

<div
  class="product-card-wrap"
  data-product-card
  data-filter-card
  data-product-id="{{ product.id }}"
  data-title="{{ product.title | escape }}"
  data-sku="{{ current_variant.sku | escape }}"
  data-tags="{{ product_tags_filter | escape }}"
  data-product-type="{{ product.type | handleize }}"
  data-category="{{ product.title | append: ' ' | append: product.type | append: ' ' | append: product_tags_filter | append: ' ' | append: product_collections_filter | strip | escape }}"
  data-collections="{{ product_collections_filter | strip | escape }}"
  data-price="{{ product.price }}"
  data-available="{% if product.available %}true{% else %}false{% endif %}"
  data-variants="{{ product_variant_filter | strip | escape }}"
  data-sizes="{{ product_size_filter | strip | escape }}"
  data-created-at="{{ product.created_at | date: '%s' }}"
>
  <button
    class="product-card-wishlist morganics-favorite-toggle"
    type="button"
    aria-label="Add {{ product.title | escape }} to wishlist"
    aria-pressed="false"
    data-favorite-toggle
    data-wishlist-product
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    data-product-title="{{ product.title | escape }}"
    data-product-url="{{ product.url }}"
    data-product-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 500 }}{% endif %}"
    data-product-price="{{ product.price | money }}"
    data-variant-id="{{ current_variant.id }}"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.8 4.6c-1.8-1.8-4.7-1.8-6.5 0L12 6.9 9.7 4.6c-1.8-1.8-4.7-1.8-6.5 0s-1.8 4.7 0 6.5L12 20l8.8-8.9c1.8-1.8 1.8-4.7 0-6.5Z"></path>
    </svg>
  </button>
  <a class="product-card morganics-product-card" href="{{ product.url }}">
    <div class="product-img{% if secondary_image != blank %} has-secondary-image{% endif %}">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: product.title, class: 'product-img-primary' }}
        {% if secondary_image != blank %}
          {{ secondary_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: product.title, class: 'product-img-secondary' }}
        {% endif %}
      {% else %}
        {% render 'morganics-product-image-fallback', product: product, width: 700, height: 700, loading: 'lazy' %}
      {% endif %}
    </div>
    <div class="product-info">
      <b class="product-name" data-urdu-wrap>{{ product.title }}</b>
      {% if product.metafields.custom.urdu_name != blank %}
        <span class="urdu-line" data-urdu-wrap>{{ product.metafields.custom.urdu_name }}</span>
      {% endif %}

      {% if product.variants.size > 1 %}
        <div class="product-card-variants-row" data-desktop-only>
          {% for variant in product.variants limit: 2 %}
            <span class="variant-item-pill">{{ variant.title }} {{ variant.price | money }}</span>
            {% unless forloop.last %}<span class="variant-separator">•</span>{% endunless %}
          {% endfor %}
          {% if product.variants.size > 2 %}
            <span class="variant-separator">•</span>
            <span class="variant-more-count">+{{ product.variants.size | minus: 2 }} more</span>
          {% endif %}
        </div>
      {% endif %}

      <div class="price-row">
        <div class="price-container">
          <span class="price{% if product.compare_at_price > product.price %} price-sale{% endif %}">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <s class="price-compare">{{ product.compare_at_price | money }}</s>
          {% endif %}
        </div>
      </div>
    </div>
  </a>

  {% if show_quick_add and product.available %}
    {% form 'product', product, class: 'card-actions' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <button class="card-cart-btn" type="submit">Add to Cart</button>
      <a class="card-view-btn" href="{{ product.url }}">View</a>
    {% endform %}
  {% elsif show_quick_add %}
    <div class="card-actions">
      <button class="card-cart-btn" type="button" disabled>Sold Out</button>
      <a class="card-view-btn" href="{{ product.url }}">View</a>
    </div>
  {% endif %}

</div>
