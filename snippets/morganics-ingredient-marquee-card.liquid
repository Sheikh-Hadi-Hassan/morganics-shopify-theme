{% liquid
  assign card_product = ingredient_product
  assign card_title = title_override | default: card_product.title
  assign card_category = category_override

  if card_category == blank and card_product.metafields.custom.category != blank
    assign card_category = card_product.metafields.custom.category.value
  endif

  if card_category == blank and card_product.collections.first != blank
    assign card_category = card_product.collections.first.title
  endif

  if card_category == blank
    assign card_category = card_product.type | default: card_product.vendor | default: 'Morganics'
  endif

  assign card_image = image_override
  if card_image == blank
    assign card_image = card_product.featured_image
  endif
  if card_image == blank and card_product.featured_media.preview_image != blank
    assign card_image = card_product.featured_media.preview_image
  endif
  if card_image == blank and card_product.images.first != blank
    assign card_image = card_product.images.first
  endif

