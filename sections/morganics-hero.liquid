{{ 'morganics-hero.css' | asset_url | stylesheet_tag }}

{% liquid
  assign nuts_link = section.settings.nuts_link | default: routes.all_products_collection_url
  assign dry_fruits_link = section.settings.dry_fruits_link | default: routes.all_products_collection_url
  assign seeds_link = section.settings.seeds_link | default: routes.all_products_collection_url

  assign almond_product = all_products['badam-abdul-wahidi']
  assign pistachio_product = all_products['pista-maghaz']
  assign cashew_product = all_products['kajo-sada']
  assign fig_product = all_products['anjeer']
  assign date_product = all_products['ajwa-dates']
  assign black_raisin_product = all_products['munaqqa']
  assign golden_raisin_product = all_products['sogi-small-kishmish-mewa']
%}

<section class="morganics-hero hero-v3" id="hero" aria-label="Morganics — Rooted in Nature" data-morganics-hero="{{ section.id }}">
  <div class="hero-bg" aria-hidden="true">
    <img src="{{ 'bg-gradient.png' | asset_url }}" alt="" class="bg-img" width="1600" height="900" loading="eager" fetchpriority="high">
    <div class="bg-vignette"></div>
    <div class="bg-tint"></div>
  </div>

  <div class="hero-corner-plants stage-plants hero-plants" aria-hidden="true">
    <div class="plant-el plant-left" data-px="-18" data-py="8">
      <img src="{{ 'plant-left.png' | asset_url }}" alt="" class="plant-img" width="420" height="420" loading="eager">
    </div>
    <div class="plant-el plant-right" data-px="18" data-py="8">
      <img src="{{ 'plant-right.png' | asset_url }}" alt="" class="plant-img" width="420" height="420" loading="eager">
    </div>
    <div class="plant-el plant-top" data-px="0" data-py="-12">
      <img src="{{ 'plant-left-top.png' | asset_url }}" alt="" class="plant-img plant-img-top" width="360" height="360" loading="eager">
    </div>
    <div class="plant-el plant-rb" data-px="14" data-py="10">
      <img src="{{ 'plant-right-bottom.png' | asset_url }}" alt="" class="plant-img" width="360" height="360" loading="eager">
    </div>
  </div>

  <div class="hero-inner">
    <div class="hero-copy">
      <div class="hero-copy-inner">
        <h1 class="hero-title">
          <span class="hero-title-sm">{{ section.settings.headline_small | escape }}</span>
          <span class="hero-title-lg">{{ section.settings.headline_large | escape }}</span>
        </h1>
        <div class="hero-rule"></div>
        <p class="hero-desc">{{ section.settings.description | escape | newline_to_br }}</p>
      </div>
    </div>

    <div class="hero-stage">
      <div class="floating-zone floating-left">
        <div class="floater f-pistachio" data-px="-14" data-py="-12">
          <img src="{{ 'pistachio.png' | asset_url }}" alt="" class="fi" width="150" height="150" loading="eager">
          <button class="hero-hotspot" data-spotlight="pistachio" aria-label="View Pista Maghaz"></button>
        </div>
        <div class="floater f-cashew" data-px="-13" data-py="6">
          <img src="{{ 'cashew.png' | asset_url }}" alt="" class="fi" width="150" height="150" loading="eager">
          <button class="hero-hotspot" data-spotlight="cashew" aria-label="View Kajo Sada"></button>
        </div>
        <div class="floater f-golden-raisin" data-px="-10" data-py="-10">
          <img src="{{ 'golden-raisin.png' | asset_url }}" alt="" class="fi" width="140" height="140" loading="eager">
          <button class="hero-hotspot" data-spotlight="golden-raisin" aria-label="View Golden Raisin"></button>
        </div>
        <div class="floater f-fig" data-px="-8" data-py="10">
          <img src="{{ 'fig.png' | asset_url }}" alt="" class="fi" width="145" height="145" loading="eager">
          <button class="hero-hotspot" data-spotlight="fig" aria-label="View Anjeer"></button>
        </div>
        <div class="floater f-date-soft" data-px="-7" data-py="8">
          <img src="{{ 'date.png' | asset_url }}" alt="" class="fi" width="130" height="130" loading="eager">
          <button class="hero-hotspot" data-spotlight="date" aria-label="View Ajwa Khajoor"></button>
        </div>
        <div class="floater f-berry-soft" data-px="-9" data-py="-7">
          <img src="{{ 'black-raisin.png' | asset_url }}" alt="" class="fi" width="135" height="135" loading="eager">
          <button class="hero-hotspot" data-spotlight="black-raisin" aria-label="View Black Munaqqa"></button>
        </div>
      </div>

      <div class="product-core hero-product-stack">
        <img src="{{ 'pouch.png' | asset_url }}" alt="Morganics Premium Organic Pouch — Chemistry of Nutrients" class="stage-pouch hero-pouch pouch-img pouch-layer" data-px="0" data-py="-3" width="560" height="680" loading="eager" fetchpriority="high">
        <div class="stage-shadow contact-shadow contact-shadow-layer" aria-hidden="true"></div>
        <img src="{{ 'dryfruit-pile.png' | asset_url }}" alt="" class="stage-dryfruits hero-dryfruits pile-img dryfruits-layer" data-px="0" data-py="6" width="780" height="420" loading="eager" aria-hidden="true">
        <img src="{{ 'stone.png' | asset_url }}" alt="" class="stage-stone hero-stone stone-img stone-layer" data-px="0" data-py="4" width="860" height="300" loading="eager" aria-hidden="true">
      </div>

      <div class="floating-zone floating-right">
        <div class="floater f-almond" data-px="12" data-py="-14">
          <img src="{{ 'almond.png' | asset_url }}" alt="" class="fi" width="145" height="145" loading="eager">
          <button class="hero-hotspot" data-spotlight="almond" aria-label="View Badam Sabat"></button>
        </div>
        <div class="floater f-walnut" data-px="11" data-py="8">
          <img src="{{ 'fig.png' | asset_url }}" alt="" class="fi" width="138" height="138" loading="eager">
          <button class="hero-hotspot" data-spotlight="fig" aria-label="View Anjeer"></button>
        </div>
        <div class="floater f-date" data-px="9" data-py="12">
          <img src="{{ 'date.png' | asset_url }}" alt="" class="fi" width="132" height="132" loading="eager">
          <button class="hero-hotspot" data-spotlight="date" aria-label="View Ajwa Khajoor"></button>
        </div>
        <div class="floater f-black-raisin" data-px="10" data-py="-8">
          <img src="{{ 'black-raisin.png' | asset_url }}" alt="" class="fi" width="135" height="135" loading="eager">
          <button class="hero-hotspot" data-spotlight="black-raisin" aria-label="View Black Munaqqa"></button>
        </div>
        <div class="floater f-golden-soft" data-px="8" data-py="7">
          <img src="{{ 'golden-raisin.png' | asset_url }}" alt="" class="fi" width="126" height="126" loading="eager">
          <button class="hero-hotspot" data-spotlight="golden-raisin" aria-label="View Golden Raisin"></button>
        </div>
        <div class="floater f-fig-soft" data-px="7" data-py="-6">
          <img src="{{ 'fig.png' | asset_url }}" alt="" class="fi" width="130" height="130" loading="eager">
          <button class="hero-hotspot" data-spotlight="fig" aria-label="View Anjeer"></button>
        </div>
      </div>

    </div>

    <div class="hero-actions">
      <div class="hero-quicklinks">
        <a class="benefit-card" href="{{ nuts_link }}" data-slide-target="nuts">
          <span class="bc-icon" aria-hidden="true">{% render 'morganics-hero-icon-premium-nuts' %}</span>
          <span class="bc-label">Premium<br>Nuts</span>
        </a>
        <a class="benefit-card" href="{{ dry_fruits_link }}" data-slide-target="dry-fruits">
          <span class="bc-icon" aria-hidden="true">{% render 'morganics-hero-icon-dry-fruits' %}</span>
          <span class="bc-label">Dry<br>Fruits</span>
        </a>
        <a class="benefit-card" href="{{ seeds_link }}" data-slide-target="seeds">
          <span class="bc-icon" aria-hidden="true">{% render 'morganics-hero-icon-seeds-wellness' %}</span>
          <span class="bc-label">Seeds &amp;<br>Wellness</span>
        </a>
      </div>
      <div class="hero-tagline" aria-hidden="true">
        <p class="tagline-sm">Driven by</p>
        <p class="tagline-lg">Wellness</p>
      </div>
    </div>
  </div>

  <article class="hero-spotlight-card" id="heroSpotlightCard-{{ section.id }}" aria-live="polite" aria-hidden="true">
    <button class="hero-spotlight-close" type="button" aria-label="Close ingredient spotlight">×</button>
    <div class="hero-spotlight-media"><img alt="" width="188" height="188"></div>
    <div class="hero-spotlight-copy">
      <h3></h3>
      <span class="hero-spotlight-urdu"></span>
      <p></p>
    </div>
    <div class="hero-spotlight-foot">
      <strong></strong>
      <div class="hero-spotlight-actions">
        <button class="hero-spotlight-add" type="button">Add to Cart</button>
        <a href="{{ routes.all_products_collection_url }}" class="hero-spotlight-cta">View Details</a>
      </div>
    </div>
  </article>

  <script type="application/json" data-hero-spotlight-products>
    {
      "almond": {
        "handle": "badam-abdul-wahidi",
        "title": "Badam Sabat",
        "urduTitle": "بادام",
        "category": "Premium Nuts",
        "description": "Whole almonds for daily snacking, soaking, family serving, and premium pantry use.",
        "fallbackImage": {{ 'almond.png' | asset_url | json }},
        "productImage": {% if almond_product.featured_image %}{{ almond_product.featured_image | image_url: width: 360 | json }}{% else %}{{ 'morganics/products/14-almond-with-shell.jpg' | asset_url | json }}{% endif %},
        "variantId": {% if almond_product.selected_or_first_available_variant %}{{ almond_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
      },
      "pistachio": {
        "handle": "pista-maghaz",
        "title": "Pista Maghaz",
        "urduTitle": "پستہ مغز",
        "category": "Premium Nuts",
        "description": "Clean pistachio kernels for premium snacking, gifting, desserts, and everyday family routines.",
        "fallbackImage": {{ 'pistachio.png' | asset_url | json }},
        "productImage": {% if pistachio_product.featured_image %}{{ pistachio_product.featured_image | image_url: width: 360 | json }}{% else %}{{ 'morganics/products/16-pista-maghaz.jpg' | asset_url | json }}{% endif %},
        "variantId": {% if pistachio_product.selected_or_first_available_variant %}{{ pistachio_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
      },
      "cashew": {
        "handle": "kajo-sada",
        "title": "Kajo Sada",
        "urduTitle": "سادہ کاجو",
        "category": "Premium Nuts",
        "description": "Creamy cashews with a naturally rich bite for clean snacking, serving, and daily energy routines.",
        "fallbackImage": {{ 'cashew.png' | asset_url | json }},
        "productImage": {% if cashew_product.featured_image %}{{ cashew_product.featured_image | image_url: width: 360 | json }}{% else %}{{ 'morganics/products/17-kajo-sada.jpg' | asset_url | json }}{% endif %},
        "variantId": {% if cashew_product.selected_or_first_available_variant %}{{ cashew_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
      },
      "fig": {
        "handle": "anjeer",
        "title": "Anjeer",
        "urduTitle": "انجیر",
        "category": "Dry Fruits",
        "description": "Naturally sweet dried figs for clean snacking, breakfast bowls, and everyday nourishment.",
        "fallbackImage": {{ 'fig.png' | asset_url | json }},
        "productImage": {% if fig_product.featured_image %}{{ fig_product.featured_image | image_url: width: 360 | json }}{% else %}{{ 'morganics/products/50-anjeer-fig.jpg' | asset_url | json }}{% endif %},
        "variantId": {% if fig_product.selected_or_first_available_variant %}{{ fig_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
      },
      "date": {
        "handle": "ajwa-dates",
        "title": "Ajwa Khajoor",
        "urduTitle": "عجوہ کھجور",
        "category": "Dry Fruits",
        "description": "Soft premium Ajwa dates for daily nourishment, Ramadan tables, gifting, and traditional routines.",
        "fallbackImage": {{ 'date.png' | asset_url | json }},
        "productImage": {% if date_product.featured_image %}{{ date_product.featured_image | image_url: width: 360 | json }}{% else %}{{ 'morganics/products/58-khajoor-ajwa.jpg' | asset_url | json }}{% endif %},
        "variantId": {% if date_product.selected_or_first_available_variant %}{{ date_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
      },
      "black-raisin": {
        "handle": "munaqqa",
        "title": "Black Munaqqa",
        "urduTitle": "منقہ",
        "category": "Dry Fruits",
        "description": "Naturally sweet dried grapes for tea-time, family routines, and traditional pantry use.",
        "fallbackImage": {{ 'black-raisin.png' | asset_url | json }},
        "productImage": {% if black_raisin_product.featured_image %}{{ black_raisin_product.featured_image | image_url: width: 360 | json }}{% else %}{{ 'morganics/products/13-munakka-black.jpg' | asset_url | json }}{% endif %},
        "variantId": {% if black_raisin_product.selected_or_first_available_variant %}{{ black_raisin_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
      },
      "golden-raisin": {
        "handle": "sogi-small-kishmish-mewa",
        "title": "Munaqqa / Golden Raisin",
        "urduTitle": "کشمش / منقہ",
        "category": "Dry Fruits",
        "description": "Naturally sweet golden dried grapes for snacking, breakfast bowls, gifting, and everyday pantry use.",
        "fallbackImage": {{ 'golden-raisin.png' | asset_url | json }},
        "productImage": {% if golden_raisin_product.featured_image %}{{ golden_raisin_product.featured_image | image_url: width: 360 | json }}{% else %}{{ 'morganics/products/29-sogi-small-mewa.jpg' | asset_url | json }}{% endif %},
        "variantId": {% if golden_raisin_product.selected_or_first_available_variant %}{{ golden_raisin_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
      }
    }
  </script>
</section>

<script src="{{ 'morganics-hero.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Morganics Hero",
  "tag": "section",
  "class": "shopify-section-morganics-hero",
  "settings": [
    { "type": "text", "id": "headline_small", "label": "Headline small", "default": "Rooted in" },
    { "type": "text", "id": "headline_large", "label": "Headline large", "default": "Nature" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Premium nuts, dry fruits\nand wellness essentials for\na healthier tomorrow" },
    { "type": "url", "id": "nuts_link", "label": "Premium Nuts link" },
    { "type": "url", "id": "dry_fruits_link", "label": "Dry Fruits link" },
    { "type": "url", "id": "seeds_link", "label": "Seeds & Wellness link" }
  ],
  "presets": [
    { "name": "Morganics Hero" }
  ]
}
{% endschema %}
