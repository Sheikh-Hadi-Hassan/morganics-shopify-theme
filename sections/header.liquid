{% liquid
  assign logo_alt = section.settings.logo.alt | default: shop.name | escape
  assign menu = section.settings.menu
%}

<header class="site-header mrg-site-header" data-morganics-header>
  <div class="header-shell mrg-header-shell">
    <a class="brand logo-brand mrg-header-brand" href="{{ routes.root_url }}" aria-label="Morganics home">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 360 | image_tag: class: 'brand-logo-img header-logo-img', alt: logo_alt, loading: 'eager' }}
      {% else %}
        <img
          class="brand-logo-img header-logo-img"
          src="{{ 'morganics/logos/morganics-logo-header.png' | asset_url }}"
          alt="Morganics - Chemistry of Nutrients"
          width="178"
          height="54"
          loading="eager"
        >
      {% endif %}
    </a>

    <nav class="header-nav mrg-desktop-nav" aria-label="Main navigation">
      <a href="{{ routes.root_url }}" {% if request.page_type == 'index' %}aria-current="page" class="active"{% endif %}>Home</a>
      <a href="{{ routes.all_products_collection_url }}" {% if request.page_type == 'collection' %}aria-current="page" class="active"{% endif %}>Shop</a>
      {% render 'morganics-mega-menu', menu: menu %}
      <a href="/pages/customer-stories">Reviews</a>
      <a href="/pages/contact">Contact</a>
      <a class="nav-pill nav-new-pill" href="{{ routes.collections_url }}/new-arrivals" data-tag="New">New Arrivals</a>
      <a class="nav-pill nav-sale-pill" href="{{ routes.collections_url }}/summer-sale" data-tag="Sale">Summer Sale</a>
    </nav>

    <div class="header-actions mrg-header-actions">
      {% if section.settings.show_search %}
        <button class="header-search-btn mrg-icon-btn" type="button" data-header-search-toggle aria-controls="MorganicsHeaderSearch" aria-expanded="false" aria-label="Search products">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.35-4.35"></path></svg>
        </button>
      {% endif %}

      <button class="wishlist-header-btn mrg-icon-btn" type="button" data-wishlist-toggle aria-label="Favourites">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"></path></svg>
        <b class="wl-badge" data-wishlist-count hidden>0</b>
      </button>

      <a class="cart-header-btn mrg-cart-btn" href="{{ routes.cart_url }}" data-cart-open aria-label="Open cart">
        <svg class="svg-ico" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 7h15l-1.5 9h-12z"></path><path d="M6 7 5.2 3H3"></path><circle cx="9" cy="20" r="1.6"></circle><circle cx="18" cy="20" r="1.6"></circle></svg>
        <span class="cart-text">Cart</span>
        <b data-cart-count>{{ cart.item_count }}</b>
      </a>

      {% if section.settings.cta_label != blank %}
        <a class="header-shop-cta" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}">
          {{ section.settings.cta_label }}
        </a>
      {% endif %}

      <button class="mobile-menu-btn" type="button" data-mobile-menu-toggle aria-controls="MorganicsMobileMenu" aria-expanded="false" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </div>

    {% if section.settings.show_search %}
      <div class="header-search-panel" id="MorganicsHeaderSearch" aria-hidden="true" data-header-search-panel>
        <script type="application/json" data-header-search-index>
          [
            {% liquid
              assign category_handles = 'roots-adaptogens|nuts-dry-fruits|oil-gums-specialties|herbs-botanicals|natural-sweetners-salts|nuts-dry-fruits|seeds-grains|all' | split: '|'
              assign category_titles = 'Roots, Botanicals & Traditional Ingredients|Dry Fruits & Heritage Mewa|Gums & Specialties|Herbs & Daily Botanicals|Natural Sweeteners & Salts|Premium Nuts|Seeds & Functional Grains|Wellness Blends' | split: '|'
              assign category_meta = 'Hareer Sabaz, Chasko Herb, Ginseng White|Zarishk Imported, Munaqqa, Anjeer|Luban, Guggul, Goond Katira|Ashwagandha, Sikakai, Amla|Gur, Fruit Salt, Shakar|Kajo Roasted, Kajo Fry, Badam Abdul Wahidi|Sarson Black, Til Black, Tukhm Methi|Triphala Blend, Salajeet' | split: '|'
              assign category_icons = 'roots-adaptogens-icon.png|dry-fruits-icon.png|oils-gums-specialties-icon.png|herbs-botanicals-icon.png|natural-sweeteners-icon.png|nuts-icon.png|seeds-grains-icon.png|oils-gums-specialties-icon.png' | split: '|'
            %}
            {% for handle in category_handles %}
              {% assign collection_item = collections[handle] %}
              {
                "title": {{ category_titles[forloop.index0] | json }},
                "handle": {{ handle | json }},
                "meta": {{ category_meta[forloop.index0] | json }},
                "url": {% if handle == 'all' %}{{ routes.all_products_collection_url | json }}{% elsif collection_item != blank %}{{ collection_item.url | json }}{% else %}{{ routes.all_products_collection_url | append: '?q=' | append: category_titles[forloop.index0] | handleize | json }}{% endif %},
                "image": {{ 'morganics/category-icons/' | append: category_icons[forloop.index0] | asset_url | json }}
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        </script>
        <script type="application/json" data-header-product-index>
          [
            {% for product in collections.all.products limit: 80 %}
              {% assign current_variant = product.selected_or_first_available_variant %}
              {
                "title": {{ product.title | json }},
                "url": {{ product.url | json }},
                "type": {{ product.type | default: product.vendor | default: 'Morganics' | json }},
                "vendor": {{ product.vendor | json }},
                "sku": {{ current_variant.sku | json }},
                "price": {{ product.price | money | json }},
                "available": {{ product.available | json }},
                "image": {% render 'morganics-product-image-fallback', product: product, output: 'url', width: 160 %}
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        </script>
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input type="hidden" name="type" value="product">
          <input class="header-search-input" name="q" autocomplete="off" placeholder="{{ section.settings.search_placeholder }}" type="search" aria-label="Search Morganics products" data-header-search-input>
          <button class="header-search-submit" type="submit" aria-label="Submit search">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.35-4.35"></path></svg>
          </button>
          <button class="header-search-close" type="button" data-header-search-close aria-label="Close search">&times;</button>
          <div class="header-search-results" role="listbox" aria-label="Search suggestions"></div>
        </form>
      </div>
    {% endif %}
  </div>
</header>

{% schema %}
{
  "name": "Morganics header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search: badam, chia, ajwain..."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Header CTA label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Header CTA link"
    }
  ]
}
{% endschema %}
