{% liquid
  assign render_category_grid = false
  if request.page_type == 'index'
    assign render_category_grid = true
  endif
  if section.id contains 'sections--'
    assign render_category_grid = false
  endif
%}

{% if render_category_grid %}
<section class="section" id="categories" data-journey-id="ingredient-finder">
  <div class="section-head reveal">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
  </div>
  <div class="category-grid">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
      {% liquid
        assign block_collection = block.settings.collection
        assign requested_icon = block.settings.icon_asset | default: 'morganics-category-icons-herbs-botanicals.png' | split: '?' | first | split: '/' | last | strip
        assign requested_icon_key = requested_icon | remove: '.png' | remove: '.webp' | remove: '.jpg' | remove: '.jpeg' | remove: 'morganics-category-icons-' | remove: '-icon'
        assign requested_icon_is_small = false
        if requested_icon contains '-icon'
          assign requested_icon_is_small = true
        endif
        assign icon_file = ''
        case requested_icon_key
          when 'dry-fruits', 'nuts', 'herbs-botanicals', 'seeds-grains', 'natural-sweeteners', 'oils-gums-specialties'
            if requested_icon_is_small
              assign icon_file = 'morganics-category-icons-' | append: requested_icon_key | append: '-icon' | append: '.png'
            else
              assign icon_file = 'morganics-category-icons-' | append: requested_icon_key | append: '.png'
            endif
          when 'roots-adaptogens', 'root-botanicals', 'roots-botanicals'
            if requested_icon_is_small
              assign icon_file = 'morganics-category-icons-roots-adaptogens-icon.png'
            else
              assign icon_file = 'morganics-category-icons-roots-adaptogens.png'
            endif
          when '8'
            assign icon_file = 'morganics-category-icons-8.png'
          when '9'
            assign icon_file = 'morganics-category-icons-9.png'
        endcase
        if icon_file == blank
          assign icon_file = 'morganics-category-icons-herbs-botanicals.png'
        endif
        assign card_title = block.settings.title
        assign card_description = block.settings.description
        assign card_url = block.settings.link | default: routes.collections_url
        assign card_kicker = block.settings.kicker
        if block_collection != blank
          assign card_url = block_collection.url
          if card_description == blank
            assign card_description = block_collection.description | strip_html
          endif
          if card_kicker == blank
            assign card_kicker = block_collection.products_count | append: ' products'
          endif
        endif
      %}
      <a class="category-icon-card" href="{{ card_url }}" {{ block.shopify_attributes }}>
        <span class="category-icon-art">
          {% if icon_file != blank %}
            <img src="{{ icon_file | asset_url }}" alt="{{ card_title | escape }} icon" width="260" height="220" loading="lazy">
          {% else %}
            <span class="category-icon-fallback" aria-hidden="true"></span>
          {% endif %}
        </span>
        <span class="category-icon-copy">
          <small>{{ card_kicker }}</small>
          <b>{{ card_title }}</b>
          <em>{{ card_description | truncate: 110 }}</em>
          <span>{{ block.settings.cta }}</span>
        </span>
      </a>
      {% endfor %}
    {% elsif collections.size > 0 %}
      {% assign rendered_count = 0 %}
      {% for collection in collections limit: 9 %}
        {% unless collection.handle == 'frontpage' %}
          {% assign rendered_count = rendered_count | plus: 1 %}
          <a class="category-icon-card" href="{{ collection.url }}">
            <span class="category-icon-art">
              {% if collection.image %}
                {{ collection.image | image_url: width: 520 | image_tag: loading: 'lazy', alt: collection.title }}
              {% else %}
                <img src="{{ 'morganics-category-icons-herbs-botanicals.png' | asset_url }}" alt="{{ collection.title | escape }} icon" width="260" height="220" loading="lazy">
              {% endif %}
            </span>
            <span class="category-icon-copy">
              <small>{{ collection.products_count }} products</small>
              <b>{{ collection.title }}</b>
              <em>{{ collection.description | strip_html | default: 'Explore Morganics pantry essentials.' | truncate: 110 }}</em>
              <span>Explore category</span>
            </span>
          </a>
        {% endunless %}
      {% endfor %}
      {% if rendered_count < 8 %}
        <a class="category-icon-card" href="{{ routes.all_products_collection_url }}?q=pantry"><span class="category-icon-art"><img src="{{ 'morganics-category-icons-oils-gums-specialties.png' | asset_url }}" alt="Pantry staples icon" width="260" height="220" loading="lazy"></span><span class="category-icon-copy"><small>Shop category</small><b>Pantry Staples</b><em>Everyday Morganics table essentials.</em><span>Explore category</span></span></a>
      {% endif %}
      {% if rendered_count < 9 %}
        <a class="category-icon-card" href="{{ routes.all_products_collection_url }}?q=wellness"><span class="category-icon-art"><img src="{{ 'morganics-category-icons-roots-adaptogens.png' | asset_url }}" alt="Wellness blends icon" width="260" height="220" loading="lazy"></span><span class="category-icon-copy"><small>Shop category</small><b>Wellness Blends</b><em>Traditional pantry picks for daily routines.</em><span>Explore category</span></span></a>
      {% endif %}
    {% else %}
      <a class="category-icon-card" href="{{ routes.all_products_collection_url }}"><span class="category-icon-art"><img src="{{ 'morganics-category-icons-dry-fruits.png' | asset_url }}" alt="Dry fruits icon" width="260" height="220" loading="lazy"></span><span class="category-icon-copy"><small>Shop category</small><b>Dry Fruits</b><em>Dates, mewa and traditional pantry staples.</em><span>Explore category</span></span></a>
      <a class="category-icon-card" href="{{ routes.all_products_collection_url }}"><span class="category-icon-art"><img src="{{ 'morganics-category-icons-nuts.png' | asset_url }}" alt="Nuts icon" width="260" height="220" loading="lazy"></span><span class="category-icon-copy"><small>Shop category</small><b>Premium Nuts</b><em>Almonds, cashews, pistachios and walnuts.</em><span>Explore category</span></span></a>
      <a class="category-icon-card" href="{{ routes.all_products_collection_url }}"><span class="category-icon-art"><img src="{{ 'morganics-category-icons-seeds-grains.png' | asset_url }}" alt="Seeds icon" width="260" height="220" loading="lazy"></span><span class="category-icon-copy"><small>Shop category</small><b>Seeds</b><em>Chia, flax, grains and clean daily pantry portions.</em><span>Explore category</span></span></a>
      <a class="category-icon-card" href="{{ routes.all_products_collection_url }}"><span class="category-icon-art"><img src="{{ 'morganics-category-icons-herbs-botanicals.png' | asset_url }}" alt="Herbs icon" width="260" height="220" loading="lazy"></span><span class="category-icon-copy"><small>Shop category</small><b>Herbs</b><em>Traditional herbs presented with modern clarity.</em><span>Explore category</span></span></a>
      <a class="category-icon-card" href="{{ routes.all_products_collection_url }}"><span class="category-icon-art"><img src="{{ 'morganics-category-icons-roots-adaptogens.png' | asset_url }}" alt="Roots icon" width="260" height="220" loading="lazy"></span><span class="category-icon-copy"><small>Shop category</small><b>Roots</b><em>Traditional-use ingredients with careful guidance.</em><span>Explore category</span></span></a>
      <a class="category-icon-card" href="{{ routes.all_products_collection_url }}"><span class="category-icon-art"><img src="{{ 'morganics-category-icons-natural-sweeteners.png' | asset_url }}" alt="Sweeteners icon" width="260" height="220" loading="lazy"></span><span class="category-icon-copy"><small>Shop category</small><b>Sweeteners</b><em>Gur, shakar, honey and natural sweetness.</em><span>Explore category</span></span></a>
    {% endif %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Morganics category grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by Category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find the ingredient your table needs today" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Choose from premium nuts, dates, seeds, herbs, botanicals, natural sweeteners and clean snacking staples." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Premium Nuts" },
        { "type": "collection", "id": "collection", "label": "Shopify collection" },
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Shop category" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Carefully selected Morganics pantry essentials." },
        { "type": "text", "id": "cta", "label": "CTA", "default": "Explore category" },
        { "type": "text", "id": "icon_asset", "label": "Icon asset", "default": "morganics-category-icons-nuts.png" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Morganics category grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Dry Fruits & Heritage Mewa", "description": "Dates, mewa and traditional gifting staples.", "icon_asset": "morganics-category-icons-dry-fruits.png" } },
        { "type": "category", "settings": { "title": "Premium Nuts", "description": "Almonds, cashews, pistachios and walnuts.", "icon_asset": "morganics-category-icons-nuts.png" } },
        { "type": "category", "settings": { "title": "Seeds & Functional Grains", "description": "Chia, sunflower, flax and clean snack portions.", "icon_asset": "morganics-category-icons-seeds-grains.png" } },
        { "type": "category", "settings": { "title": "Herbs & Daily Botanicals", "description": "Traditional herbs presented with modern clarity.", "icon_asset": "morganics-category-icons-herbs-botanicals.png" } },
        { "type": "category", "settings": { "title": "Roots & Botanicals", "description": "Traditional-use ingredients with careful guidance.", "icon_asset": "morganics-category-icons-roots-adaptogens.png" } },
        { "type": "category", "settings": { "title": "Natural Sweeteners", "description": "Gur, shakar, honey and pantry sweetness.", "icon_asset": "morganics-category-icons-natural-sweeteners.png" } }
      ]
    }
  ]
}
{% endschema %}
