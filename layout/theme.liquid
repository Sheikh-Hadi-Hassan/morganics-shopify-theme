<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#285D53">

    {% render 'css-variables' %}

    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'morganics-theme.css' | asset_url | stylesheet_tag }}

    <style>
      @font-face {
        font-family: 'Brownberries';
        src: url({{ 'morganics/fonts/Brown-Beige.otf' | asset_url }}) format('opentype');
        font-weight: 400 900;
        font-style: normal;
        font-display: swap;
      }
    </style>

    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body data-template="{{ template.name | escape }}">
    <div class="grain" aria-hidden="true"></div>

    {% sections 'header-group' %}

    <main id="MainContent" class="morganics-main" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script src="{{ 'morganics-theme.js' | asset_url }}" defer></script>
  </body>
</html>
