{% liquid
  assign logo_alt = section.settings.logo.alt | default: shop.name | escape
%}

<footer class="premium-footer">
  <div class="footer-inner footer-grid-wrap">
    <div class="footer-grid">
      <div class="footer-col footer-brand-col">
        <a href="{{ routes.root_url }}" class="footer-logo-link" aria-label="{{ shop.name }} home">
          {% if section.settings.logo != blank %}
            {{ section.settings.logo | image_url: width: 420 | image_tag: class: 'footer-logo', alt: logo_alt, loading: 'lazy' }}
          {% else %}
            <img class="footer-logo" src="{{ 'morganics-logos-morganics-logo-footer.png' | asset_url }}" alt="Morganics - Chemistry of Nutrients" width="220" height="96" loading="lazy">
          {% endif %}
        </a>

        {% if section.settings.brand_text != blank %}
          <p class="footer-brand-desc">{{ section.settings.brand_text }}</p>
        {% endif %}

        <div class="footer-brand-pills">
          {% if section.settings.pill_1 != blank %}<span>{{ section.settings.pill_1 }}</span>{% endif %}
          {% if section.settings.pill_2 != blank %}<span>{{ section.settings.pill_2 }}</span>{% endif %}
          {% if section.settings.pill_3 != blank %}<span>{{ section.settings.pill_3 }}</span>{% endif %}
        </div>
      </div>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'menu_column' %}
            <div class="footer-col" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h4 class="footer-col-title">{{ block.settings.heading }}</h4>
              {% endif %}
              <nav class="footer-links" aria-label="{{ block.settings.heading | escape }}">
                {% if block.settings.heading contains 'Care' %}
                  <a href="/pages/contact">Contact Morganics</a>
                  <a href="/pages/faq">FAQ</a>
                  <a href="/pages/shipping-policy">Shipping Policy</a>
                  <a href="/pages/return-refund-policy">Return &amp; Refund Policy</a>
                  <a href="/pages/payment-policy">Payment Policy</a>
                  <a href="/pages/contact">Custom Sourcing</a>
                {% elsif block.settings.heading contains 'Trust' %}
                  <a href="/pages/about-us">About Us</a>
                  <a href="/pages/privacy-policy">Privacy Policy</a>
                  <a href="/pages/terms-conditions">Terms &amp; Conditions</a>
                  <a href="/pages/storage-guide">Storage Guide</a>
                  <a href="/pages/ingredient-guide">Ingredient Guide</a>
                  <a href="/pages/guides">Guides</a>
                {% elsif block.settings.heading contains 'Business' %}
                  <a href="/pages/bulk-corporate-orders">Bulk / Corporate Orders</a>
                  <a href="/pages/contact">Custom Sourcing</a>
                  <a href="mailto:hello@morganics.store">Sales Email</a>
                  <a href="https://wa.me/923223338110" target="_blank" rel="noopener">WhatsApp Quote</a>
                {% else %}
                  <a href="{{ routes.all_products_collection_url }}">All Products</a>
                  <a href="{{ routes.collections_url }}/nuts">Nuts</a>
                  <a href="{{ routes.collections_url }}/seeds">Seeds</a>
                  <a href="{{ routes.collections_url }}/herbs">Herbs</a>
                  <a href="{{ routes.collections_url }}/dry-fruits">Dry Fruits</a>
                  <a href="{{ routes.collections_url }}/botanicals">Botanicals</a>
                  <a href="{{ routes.collections_url }}/gums-specialties">Gums &amp; Specialties</a>
                  <a href="/pages/ingredient-guide">Ingredient Guide</a>
                  <a href="/pages/storage-guide">Storage Guide</a>
                {% endif %}
              </nav>
            </div>

          {% when 'text_column' %}
            <div class="footer-col" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h4 class="footer-col-title">{{ block.settings.heading }}</h4>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="footer-richtext">{{ block.settings.text }}</div>
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}

      <div class="footer-col footer-connect-col">
        <h4 class="footer-col-title">{{ section.settings.contact_heading }}</h4>
        <div class="footer-contact-list">
          {% if section.settings.phone_label != blank %}
            <a href="tel:{{ section.settings.phone_tel | remove: ' ' }}" class="footer-contact-link">
              <span class="footer-inline-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"><path d="M20 11.6a8.3 8.3 0 0 1-12.2 7.3L4 20l1.1-3.6A8.3 8.3 0 1 1 20 11.6Z"></path><path d="M9.3 8.7c.2-.5.4-.5.7-.5h.6c.2 0 .5.1.6.4l.8 1.8c.1.3 0 .5-.1.7l-.4.5c-.2.2-.3.4-.1.7.5 1 1.3 1.8 2.4 2.4.3.2.5.1.7-.1l.6-.7c.2-.2.4-.2.7-.1l1.7.8c.3.1.4.4.4.7 0 .6-.4 1.2-.9 1.5-.7.4-1.6.4-2.9-.1-2.5-.9-4.6-3-5.6-5.5-.5-1.3-.5-2.2-.1-2.9Z"></path></svg></span>
              <span>{{ section.settings.phone_label }}</span>
            </a>
          {% endif %}
          {% if section.settings.email != blank %}
            <a href="mailto:{{ section.settings.email }}" class="footer-contact-link">
              <span class="footer-inline-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16v12H4z"></path><path d="m4 7 8 6 8-6"></path></svg></span>
              <span>{{ section.settings.email }}</span>
            </a>
          {% endif %}
        </div>

        <div class="footer-socials">
          <a href="{{ section.settings.instagram_url | default: routes.root_url }}" {% if section.settings.instagram_url != blank %}target="_blank" rel="noopener"{% endif %} class="footer-social-pill"><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="4"></rect><circle cx="12" cy="12" r="3.2"></circle><path d="M17.4 6.8h.01"></path></svg></span>Instagram</a>
          <a href="{{ section.settings.facebook_url | default: routes.root_url }}" {% if section.settings.facebook_url != blank %}target="_blank" rel="noopener"{% endif %} class="footer-social-pill"><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14.2 8.3V6.9c0-.7.5-.9.9-.9H17V3h-2.7c-3 0-3.7 2.2-3.7 3.7v1.6H8.2v3.3h2.4V21h3.6v-9.4h2.7l.4-3.3h-3.1Z"></path></svg></span>Facebook</a>
          <a href="{{ section.settings.tiktok_url | default: routes.root_url }}" {% if section.settings.tiktok_url != blank %}target="_blank" rel="noopener"{% endif %} class="footer-social-pill"><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M15.4 3c.4 2.5 1.8 4 4.3 4.2v3.2c-1.5.1-2.9-.4-4.2-1.2v6.1c0 3.1-1.9 5.7-5.4 5.7-3 0-5.1-2-5.1-4.8 0-3.2 2.5-5.1 5.7-4.7v3.4c-1.4-.4-2.4.3-2.4 1.3 0 .9.7 1.5 1.7 1.5 1.2 0 2-.7 2-2.3V3h3.4Z"></path></svg></span>TikTok</a>
          <a href="{{ section.settings.youtube_url | default: routes.root_url }}" {% if section.settings.youtube_url != blank %}target="_blank" rel="noopener"{% endif %} class="footer-social-pill"><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.6 7.2a3 3 0 0 0-2.1-2.1C17.7 4.6 12 4.6 12 4.6s-5.7 0-7.5.5a3 3 0 0 0-2.1 2.1C2 9 2 12 2 12s0 3 .4 4.8a3 3 0 0 0 2.1 2.1c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a3 3 0 0 0 2.1-2.1C22 15 22 12 22 12s0-3-.4-4.8ZM10 15.4V8.6l5.7 3.4-5.7 3.4Z"></path></svg></span>YouTube</a>
        </div>

        <div class="footer-newsletter">
          <h5>Seasonal Wellness Drops</h5>
          {% form 'customer', class: 'footer-newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <label class="visually-hidden" for="FooterNewsletterEmail-{{ section.id }}">Email address</label>
            <input id="FooterNewsletterEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="your@email.com" autocomplete="email" required>
            <button type="submit">Join</button>
          {% endform %}
        </div>
      </div>
    </div>

    <div class="footer-support-bars" aria-label="Footer quick actions">
      {% if section.settings.whatsapp_url != blank %}
        <a class="footer-cta" href="{{ section.settings.whatsapp_url }}" target="_blank" rel="noopener">
          <span class="footer-icon-box" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"><path d="M20 11.6a8.3 8.3 0 0 1-12.2 7.3L4 20l1.1-3.6A8.3 8.3 0 1 1 20 11.6Z"></path><path d="M9.3 8.7c.2-.5.4-.5.7-.5h.6c.2 0 .5.1.6.4l.8 1.8c.1.3 0 .5-.1.7l-.4.5c-.2.2-.3.4-.1.7.5 1 1.3 1.8 2.4 2.4.3.2.5.1.7-.1l.6-.7c.2-.2.4-.2.7-.1l1.7.8c.3.1.4.4.4.7 0 .6-.4 1.2-.9 1.5-.7.4-1.6.4-2.9-.1-2.5-.9-4.6-3-5.6-5.5-.5-1.3-.5-2.2-.1-2.9Z"></path></svg></span>
          <span><b>WhatsApp Order</b><small>Chat with us to place your order</small></span>
          <em aria-hidden="true">&rarr;</em>
        </a>
      {% elsif section.settings.phone_tel != blank %}
        <a class="footer-cta" href="https://wa.me/{{ section.settings.phone_tel | remove: '+' | remove: ' ' }}" target="_blank" rel="noopener">
          <span class="footer-icon-box" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"><path d="M20 11.6a8.3 8.3 0 0 1-12.2 7.3L4 20l1.1-3.6A8.3 8.3 0 1 1 20 11.6Z"></path><path d="M9.3 8.7c.2-.5.4-.5.7-.5h.6c.2 0 .5.1.6.4l.8 1.8c.1.3 0 .5-.1.7l-.4.5c-.2.2-.3.4-.1.7.5 1 1.3 1.8 2.4 2.4.3.2.5.1.7-.1l.6-.7c.2-.2.4-.2.7-.1l1.7.8c.3.1.4.4.4.7 0 .6-.4 1.2-.9 1.5-.7.4-1.6.4-2.9-.1-2.5-.9-4.6-3-5.6-5.5-.5-1.3-.5-2.2-.1-2.9Z"></path></svg></span>
          <span><b>WhatsApp Order</b><small>Chat with us to place your order</small></span>
          <em aria-hidden="true">&rarr;</em>
        </a>
      {% endif %}
      {% if section.settings.support_email != blank %}
        <a class="footer-cta" href="mailto:{{ section.settings.support_email }}">
          <span class="footer-icon-box" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16v12H4z"></path><path d="m4 7 8 6 8-6"></path></svg></span>
          <span><b>Support Email</b><small>{{ section.settings.support_email }}</small></span>
          <em aria-hidden="true">&rarr;</em>
        </a>
      {% endif %}
      <a class="footer-cta" href="/pages/bulk-corporate-orders">
        <span class="footer-icon-box" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.15" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z"></path><path d="m12 8 4 2.3v4.4L12 17l-4-2.3v-4.4L12 8Z"></path></svg></span>
        <span><b>Bulk & Custom Sourcing</b><small>Wholesale & special requirements</small></span>
        <em aria-hidden="true">&rarr;</em>
      </a>
    </div>
  </div>

  <div class="footer-bottom-bar">
    <div class="footer-inner footer-bottom-inner">
      <span class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}</span>
      <nav class="footer-policy-links" aria-label="Footer policies">
        <a href="/pages/privacy-policy">Privacy Policy</a>
        <a href="/pages/terms-conditions">Terms</a>
        <a href="/pages/shipping-policy">Shipping</a>
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Morganics footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand text",
      "default": "Premium natural pantry essentials for Pakistani homes, sourced with care and packed with purity."
    },
    {
      "type": "text",
      "id": "pill_1",
      "label": "Brand pill 1",
      "default": "COD Delivery"
    },
    {
      "type": "text",
      "id": "pill_2",
      "label": "Brand pill 2",
      "default": "Premium Pantry"
    },
    {
      "type": "text",
      "id": "pill_3",
      "label": "Brand pill 3",
      "default": "Natural Ingredients"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Connect"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone display",
      "default": "+92 322 3338110"
    },
    {
      "type": "text",
      "id": "phone_tel",
      "label": "Phone link value",
      "default": "+923223338110"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Sales email",
      "default": "hello@morganics.store"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@morganics.store"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom policy menu"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright line",
      "default": "Pure by Nature. Premium by Choice."
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text_column",
      "name": "Text column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Customer Care"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Contact Morganics for ingredient guidance, custom sourcing, and support.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Morganics footer",
      "blocks": [
        { "type": "menu_column" },
        { "type": "menu_column" }
      ]
    }
  ]
}
{% endschema %}
