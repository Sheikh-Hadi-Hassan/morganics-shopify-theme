<section class="routine-section" id="dayCarousel" data-journey-id="daily-needs" aria-label="{{ section.settings.aria_label | escape }}">
  <div class="routine-bg" aria-hidden="true"></div>
  <div class="routine-overlay" aria-hidden="true"></div>
  <div class="routine-content reveal">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="routine-heading">{{ section.settings.heading }}</h2>
    <p class="routine-desc">{{ section.settings.text }}</p>
    <div class="routine-actions">
      {% if section.settings.primary_label != blank %}<a class="btn" href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}">{{ section.settings.primary_label }}</a>{% endif %}
      {% if section.settings.secondary_label != blank %}<a class="btn ghost" href="{{ section.settings.secondary_link | default: '#categories' }}">{{ section.settings.secondary_label }}</a>{% endif %}
    </div>
    <div class="routine-cards">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% liquid
            assign requested_icon = block.settings.icon_asset | default: 'morganics-category-icons-dry-fruits.png' | split: '?' | first | split: '/' | last | strip
            assign requested_icon_key = requested_icon | remove: '.png' | remove: '.webp' | remove: '.jpg' | remove: '.jpeg' | remove: 'morganics-category-icons-' | remove: '-icon'
            assign requested_icon_is_small = false
            if requested_icon contains '-icon'
              assign requested_icon_is_small = true
            endif
            assign icon_file = ''
            case requested_icon_key
              when 'dry-fruits', 'nuts', 'herbs-botanicals', 'seeds-grains', 'natural-sweeteners', 'oils-gums-specialties'
                if requested_icon_is_small
                  assign icon_file = 'morganics-category-icons-' | append: requested_icon_key | append: '-icon' | append: '.png'
                else
                  assign icon_file = 'morganics-category-icons-' | append: requested_icon_key | append: '.png'
                endif
              when 'roots-adaptogens', 'root-botanicals', 'roots-botanicals'
                if requested_icon_is_small
                  assign icon_file = 'morganics-category-icons-roots-adaptogens-icon.png'
                else
                  assign icon_file = 'morganics-category-icons-roots-adaptogens.png'
                endif
              when '8'
                assign icon_file = 'morganics-category-icons-8.png'
              when '9'
                assign icon_file = 'morganics-category-icons-9.png'
            endcase
            if icon_file == blank
              assign icon_file = 'morganics-category-icons-dry-fruits.png'
            endif
          %}
          <a class="routine-card" href="{{ block.settings.link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
            <span class="rc-thumb">
              {% if icon_file != blank %}
                <img src="{{ icon_file | asset_url }}" alt="{{ block.settings.nav | escape }} routine" width="96" height="96" loading="lazy">
              {% else %}
                <span class="category-icon-fallback" aria-hidden="true"></span>
              {% endif %}
            </span>
            <span class="rc-copy"><small>{{ block.settings.nav }}</small><b>{{ block.settings.title }}</b><em>{{ block.settings.text }}</em></span>
            <span class="rc-arrow">→</span>
          </a>
        {% endfor %}
      {% else %}
        <a class="routine-card" href="{{ routes.all_products_collection_url }}?q=family"><span class="rc-thumb"><img src="{{ 'morganics-category-icons-dry-fruits.png' | asset_url }}" alt="Family routine" width="96" height="96" loading="lazy"></span><span class="rc-copy"><small>Family</small><b>Daily Family Table</b><em>Dates, mewa and nuts for home tables and hospitality</em></span><span class="rc-arrow">→</span></a>
        <a class="routine-card" href="{{ routes.all_products_collection_url }}?q=energy"><span class="rc-thumb"><img src="{{ 'morganics-category-icons-nuts.png' | asset_url }}" alt="Energy routine" width="96" height="96" loading="lazy"></span><span class="rc-copy"><small>Energy</small><b>Daily Energy</b><em>Badam, chia and dates for breakfast, office and school</em></span><span class="rc-arrow">→</span></a>
        <a class="routine-card" href="{{ routes.all_products_collection_url }}?q=cooling"><span class="rc-thumb"><img src="{{ 'morganics-category-icons-seeds-grains.png' | asset_url }}" alt="Cooling routine" width="96" height="96" loading="lazy"></span><span class="rc-copy"><small>Cooling</small><b>Summer Cooling</b><em>Goond Katira, chia and seeds for hot Pakistani days</em></span><span class="rc-arrow">→</span></a>
        <a class="routine-card" href="{{ routes.all_products_collection_url }}?q=digestive"><span class="rc-thumb"><img src="{{ 'morganics-category-icons-herbs-botanicals.png' | asset_url }}" alt="Digestive routine" width="96" height="96" loading="lazy"></span><span class="rc-copy"><small>Digestive</small><b>Digestive Pantry</b><em>Ajwain, isabgol and fruit salt for careful daily use</em></span><span class="rc-arrow">→</span></a>
        <a class="routine-card" href="{{ routes.all_products_collection_url }}?q=gifting"><span class="rc-thumb"><img src="{{ 'morganics-category-icons-natural-sweeteners.png' | asset_url }}" alt="Gifting routine" width="96" height="96" loading="lazy"></span><span class="rc-copy"><small>Gifting</small><b>Ramadan &amp; Gifting</b><em>Dates, saffron, honey and mewa for thoughtful occasions</em></span><span class="rc-arrow">→</span></a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Morganics routines",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "Shop Morganics by lifestyle routine" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by Routine" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose what your day needs." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Pick the moment first, then discover Morganics products for energy, healthy snacking, cooling, digestion or gifting." },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Explore Shop" },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Explore Categories" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" }
  ],
  "blocks": [
    {
      "type": "routine",
      "name": "Routine card",
      "settings": [
        { "type": "text", "id": "nav", "label": "Label", "default": "Family" },
        { "type": "text", "id": "title", "label": "Title", "default": "Daily Family Table" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Dates, mewa and nuts for home tables and hospitality" },
        { "type": "text", "id": "icon_asset", "label": "Icon asset", "default": "morganics-category-icons-dry-fruits.png" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Morganics routine carousel",
      "blocks": [
        { "type": "routine", "settings": { "nav": "Family", "title": "Daily Family Table", "text": "Dates, mewa and nuts for home tables and hospitality", "icon_asset": "morganics-category-icons-dry-fruits.png" } },
        { "type": "routine", "settings": { "nav": "Energy", "title": "Daily Energy", "text": "Badam, chia and dates for breakfast, office and school", "icon_asset": "morganics-category-icons-nuts.png" } },
        { "type": "routine", "settings": { "nav": "Cooling", "title": "Summer Cooling", "text": "Goond Katira, chia and seeds for hot Pakistani days", "icon_asset": "morganics-category-icons-seeds-grains.png" } },
        { "type": "routine", "settings": { "nav": "Digestive", "title": "Digestive Pantry", "text": "Ajwain, isabgol and fruit salt for careful daily use", "icon_asset": "morganics-category-icons-herbs-botanicals.png" } },
        { "type": "routine", "settings": { "nav": "Gifting", "title": "Ramadan & Gifting", "text": "Dates, saffron, honey and mewa for thoughtful occasions", "icon_asset": "morganics-category-icons-natural-sweeteners.png" } }
      ]
    }
  ]
}
{% endschema %}
