<section class="section featured-products-section" id="featured" data-journey-id="popular-products" data-homepage-products-section>
  <div class="section-head reveal">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
  </div>




  <style>
    /* Featured products grid — matches shop page exactly */
    #featured .product-grid.morganics-product-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
    }
    @media (max-width: 900px) {
      #featured .product-grid.morganics-product-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
        gap: 12px !important;
      }
    }
    @media (max-width: 767px) {
      #featured .product-grid.morganics-product-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
        gap: 8px !important;
      }
      #featured .product-card-wrap { border-radius: 14px !important; max-width: none !important; margin-inline: 0 !important; }
      #featured .product-card-wrap .product-info { padding: 7px 8px 5px !important; }
      #featured .product-card-wrap .product-name { font-size: 11px !important; font-weight: 800 !important; line-height: 1.3 !important; min-height: unset !important; display: -webkit-box !important; -webkit-line-clamp: 2 !important; -webkit-box-orient: vertical !important; overflow: hidden !important; }
      #featured .product-card-wrap .urdu-line,
      #featured .product-card-wrap .product-card-variants-row { display: none !important; }
      #featured .product-card-wrap .price { font-size: 11px !important; font-weight: 900 !important; }
      #featured .product-card-wrap .price-compare { font-size: 10px !important; }
      #featured .product-card-wishlist { width: 30px !important; height: 30px !important; top: 6px !important; right: 6px !important; }
      #featured .product-card-wishlist svg { width: 14px !important; height: 14px !important; }
      #featured .card-actions { padding: 0 6px 7px !important; gap: 5px !important; grid-template-columns: 1fr 1fr !important; }
      #featured .card-cart-btn, #featured .card-view-btn { min-height: 28px !important; height: 28px !important; font-size: 10px !important; padding: 0 5px !important; }
    }
  </style>

  <div
    class="product-grid morganics-product-grid"
    data-view="grid"
  >
    {% if section.settings.products != blank %}
      {% for product in section.settings.products limit: section.settings.limit %}
        {% render 'morganics-product-card', product: product, show_quick_add: section.settings.show_quick_add %}
      {% endfor %}
    {% elsif section.settings.collection != blank and section.settings.collection.products.size > 0 %}
      {% for product in section.settings.collection.products limit: section.settings.limit %}
        {% render 'morganics-product-card', product: product, show_quick_add: section.settings.show_quick_add %}
      {% endfor %}
    {% elsif collections.all.products.size > 0 %}
      {% for product in collections.all.products limit: section.settings.limit %}
        {% render 'morganics-product-card', product: product, show_quick_add: section.settings.show_quick_add %}
      {% endfor %}
    {% else %}
      {% for block in section.blocks %}
        {% assign image_file = block.settings.image_asset | default: 'morganics-products-16-pista-maghaz.jpg' %}
        <a class="product-card" href="{{ block.settings.link | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
          <div class="product-img"><img src="{{ image_file | asset_url }}" alt="{{ block.settings.title | escape }}" width="700" height="700" loading="lazy"></div>
          <div class="product-info">
            <small>{{ block.settings.meta }}</small>
            <b>{{ block.settings.title }}</b>
            <div class="price-row"><span class="price">{{ block.settings.price }}</span></div>
          </div>
        </a>
      {% endfor %}
    {% endif %}
  </div>
  {% if section.settings.button_label != blank %}
    <div class="center"><a class="btn" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a></div>
  {% endif %}

  <script>
    (function() {
      function initHomepageGrid(section) {
        const gridContainer = section.querySelector('.morganics-product-grid');
        if (!gridContainer || section.dataset.homepageGridInitialized === 'true') return;
        section.dataset.homepageGridInitialized = 'true';
        // Ensure grid view is always active on homepage
        gridContainer.setAttribute('data-view', 'grid');
        gridContainer.classList.remove('is-list-view');
      }

      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[data-homepage-products-section]').forEach(initHomepageGrid);
      });

      document.addEventListener('shopify:section:load', (event) => {
        if (event.target.querySelector('[data-homepage-products-section]')) {
          initHomepageGrid(event.target.querySelector('[data-homepage-products-section]'));
        }
      });
    })();
  </script>
</section>

{% schema %}
{
  "name": "Morganics featured",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured Products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Popular Morganics essentials" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Quick picks for daily use, thoughtful gifting and wellness routines." },
    { "type": "product_list", "id": "products", "label": "Shopify products" },
    { "type": "collection", "id": "collection", "label": "Fallback Shopify collection" },
    { "type": "range", "id": "limit", "label": "Product limit", "min": 2, "max": 12, "step": 1, "default": 9 },
    { "type": "checkbox", "id": "show_quick_add", "label": "Show quick add", "default": true },
    { "type": "checkbox", "id": "show_toolbar", "label": "Show toolbar (search, sort, view toggle)", "default": false },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Open Full Shop" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "placeholder_product",
      "name": "Placeholder product",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Pista Maghaz" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "Nuts" },
        { "type": "text", "id": "price", "label": "Price", "default": "Shop product" },
        { "type": "text", "id": "image_asset", "label": "Image asset", "default": "morganics-products-16-pista-maghaz.jpg" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Morganics featured products",
      "blocks": [
        { "type": "placeholder_product", "settings": { "title": "Pista Maghaz", "meta": "Nuts", "image_asset": "morganics-products-16-pista-maghaz.jpg" } },
        { "type": "placeholder_product", "settings": { "title": "Kajo Sada", "meta": "Nuts", "image_asset": "morganics-products-17-kajo-sada.jpg" } },
        { "type": "placeholder_product", "settings": { "title": "Khajoor Ajwa", "meta": "Dry Fruits", "image_asset": "morganics-products-58-khajoor-ajwa.jpg" } },
        { "type": "placeholder_product", "settings": { "title": "Goond Katira", "meta": "Gums & Specialties", "image_asset": "morganics-products-49-goond-katira.jpg" } }
      ]
    }
  ]
}
{% endschema %}
