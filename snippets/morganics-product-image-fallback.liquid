{% if output == 'url' %}
  {% if product.featured_image %}
    {{ product.featured_image | image_url: width: fallback_width | json }}
  {% elsif fallback_image_asset != blank %}
    {{ fallback_image_asset | asset_url | json }}
  {% else %}
    {{ 'morganics/logos/morganics-logo-header.png' | asset_url | json }}
  {% endif %}
{% elsif fallback_image_asset != blank %}
  <img src="{{ fallback_image_asset | asset_url }}" alt="{{ fallback_alt | escape }}" width="{{ width | default: 700 }}" height="{{ height | default: 700 }}" loading="{{ loading | default: 'lazy' }}">
{% else %}
  <img src="{{ 'morganics/logos/morganics-logo-header.png' | asset_url }}" alt="{{ fallback_alt | escape }}" width="{{ width | default: 700 }}" height="{{ height | default: 700 }}" loading="{{ loading | default: 'lazy' }}">
{% endif %}
