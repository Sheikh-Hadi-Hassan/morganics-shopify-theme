{% liquid
  assign all_url = routes.all_products_collection_url
  assign roots_collection = collections['roots-adaptogens']
  assign dry_collection = collections['nuts-dry-fruits']
  assign gums_collection = collections['oil-gums-specialties']
  assign herbs_collection = collections['herbs-botanicals']
  assign sweet_collection = collections['natural-sweetners-salts']
  assign seeds_collection = collections['seeds-grains']
%}

<div class="mega-wrap" data-mega-wrap>
  <a class="mega-trigger" href="{{ routes.collections_url }}" aria-haspopup="true" aria-expanded="false" data-mega-trigger>Categories</a>

  <div class="mega-menu" aria-hidden="true" data-mega-menu>
    <div class="mega-panel">
      <div class="mega-intro">
        <span class="mega-eyebrow">Shop by Category</span>
        <h3>Morganics Pantry</h3>
        <p>Choose by category, routine and product type. Every category uses clean ingredient icons instead of heavy banners for faster browsing.</p>
        <a class="mega-cta" href="{{ all_url }}">Open Full Shop</a>
      </div>

      <div class="mega-cats" aria-label="Morganics category shortcuts">
        <a class="mega-cat" href="{% if roots_collection != blank %}{{ roots_collection.url }}{% else %}{{ all_url }}{% endif %}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-roots-adaptogens-icon.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Roots, Botanicals &amp; Traditional Ingredients</b><small>Hareer Sabaz, Chasko Herb, Ginseng White</small></span>
        </a>

        <a class="mega-cat" href="{% if dry_collection != blank %}{{ dry_collection.url }}{% else %}{{ all_url }}{% endif %}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-dry-fruits-icon.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Dry Fruits &amp; Heritage Mewa</b><small>Zarishk Imported, Munaqqa, Anjeer</small></span>
        </a>

        <a class="mega-cat" href="{% if gums_collection != blank %}{{ gums_collection.url }}{% else %}{{ all_url }}{% endif %}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-oils-gums-specialties-icon.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Gums &amp; Specialties</b><small>Luban, Guggul, Goond Katira</small></span>
        </a>

        <a class="mega-cat" href="{% if herbs_collection != blank %}{{ herbs_collection.url }}{% else %}{{ all_url }}{% endif %}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-herbs-botanicals-icon.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Herbs &amp; Daily Botanicals</b><small>Ashwagandha, Sikakai, Amla</small></span>
        </a>

        <a class="mega-cat" href="{% if sweet_collection != blank %}{{ sweet_collection.url }}{% else %}{{ all_url }}{% endif %}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-natural-sweeteners-icon.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Natural Sweeteners &amp; Salts</b><small>Gur, Fruit Salt, Shakar</small></span>
        </a>

        <a class="mega-cat" href="{% if dry_collection != blank %}{{ dry_collection.url }}{% else %}{{ all_url }}{% endif %}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-nuts-icon.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Premium Nuts</b><small>Kajo Roasted, Kajo Fry, Badam Abdul Wahidi</small></span>
        </a>

        <a class="mega-cat" href="{{ all_url }}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-8.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Premium Snacks &amp; Pantry Staples</b><small>Sogi Big Kishmish Mewa, Sogi Small Kishmish Mewa, Phool Makhana</small></span>
        </a>

        <a class="mega-cat" href="{% if seeds_collection != blank %}{{ seeds_collection.url }}{% else %}{{ all_url }}{% endif %}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-seeds-grains-icon.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Seeds &amp; Functional Grains</b><small>Sarson Black, Til Black, Tukhm Methi</small></span>
        </a>

        <a class="mega-cat" href="{{ all_url }}">
          <span class="mega-cat-icon"><img src="{{ 'morganics-category-icons-9.png' | asset_url }}" alt="" width="96" height="96" loading="lazy"></span>
          <span class="mega-cat-copy"><b>Wellness Blends</b><small>Triphala Blend, Salajeet</small></span>
        </a>
      </div>
    </div>
  </div>
</div>
