<form class="shop-tools" method="get" action="{{ collection.url | default: routes.search_url }}" data-collection-tools>
  {% if search_mode %}
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ search_placeholder | default: 'Search Morganics products...' }}">
    <input type="hidden" name="type" value="product">
  {% else %}
    <input type="search" name="filter.v.availability" value="" placeholder="{{ search_placeholder | default: 'Use Shopify filters from the sidebar' }}" disabled>
  {% endif %}

  {% if collection.sort_options != blank %}
    <select name="sort_by" aria-label="Sort products">
      {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
      {% for option in collection.sort_options %}
        <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
      {% endfor %}
    </select>
  {% endif %}

  <button class="btn ghost" type="submit">{{ button_label | default: 'Apply' }}</button>
</form>
