{% comment %}
  Password storefront page shown while Shopify password protection is enabled.
{% endcomment %}

{% liquid
  assign launch_date = section.settings.launch_date | default: '10 June'
  assign launch_time = section.settings.launch_time | default: '11:00 AM'
%}

<section class="morganics-password" aria-labelledby="PasswordLaunchTitle">
  <header class="morganics-password__bar">
    <a class="morganics-password__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <img
        src="{{ 'morganics/logos/morganics-logo-header.png' | asset_url }}"
        alt="{{ shop.name }}"
        width="276"
        height="82"
        loading="eager"
      >
    </a>

    <details class="morganics-password__access">
      <summary>
        <span aria-hidden="true">Lock</span>
        <span>{{ section.settings.password_label }}</span>
      </summary>
      <div class="morganics-password__access-panel">
        {% form 'storefront_password', class: 'morganics-password__access-form' %}
          {% if form.errors %}
            <div class="morganics-password__form-message morganics-password__form-message--error">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <label for="PasswordInput">{{ section.settings.password_input_label }}</label>
          <div class="morganics-password__access-row">
            <input
              id="PasswordInput"
              type="password"
              name="password"
              autocomplete="current-password"
              placeholder="{{ section.settings.password_placeholder | escape }}"
            >
            <button type="submit">{{ section.settings.password_button }}</button>
          </div>
        {% endform %}
      </div>
    </details>
  </header>

  <div class="morganics-password__stage" aria-hidden="true">
    <img class="morganics-password__plant morganics-password__plant--left" src="{{ 'plant-left.png' | asset_url }}" alt="" width="390" height="390" loading="eager">
    <img class="morganics-password__plant morganics-password__plant--right" src="{{ 'plant-right.png' | asset_url }}" alt="" width="390" height="390" loading="eager">
    <img class="morganics-password__stone" src="{{ 'stone.png' | asset_url }}" alt="" width="760" height="240" loading="eager">
    <img class="morganics-password__pouch" src="{{ 'pouch.png' | asset_url }}" alt="" width="620" height="820" loading="eager">
    <img class="morganics-password__pile" src="{{ 'dryfruit-pile.png' | asset_url }}" alt="" width="760" height="320" loading="eager">

    <img class="morganics-password__float morganics-password__float--almond" src="{{ 'almond.png' | asset_url }}" alt="" width="96" height="96" loading="eager">
    <img class="morganics-password__float morganics-password__float--date" src="{{ 'date.png' | asset_url }}" alt="" width="96" height="96" loading="eager">
    <img class="morganics-password__float morganics-password__float--fig" src="{{ 'fig.png' | asset_url }}" alt="" width="96" height="96" loading="eager">
    <img class="morganics-password__float morganics-password__float--cashew" src="{{ 'cashew.png' | asset_url }}" alt="" width="96" height="96" loading="eager">
    <img class="morganics-password__float morganics-password__float--raisin" src="{{ 'black-raisin.png' | asset_url }}" alt="" width="96" height="96" loading="eager">
  </div>

  <div class="morganics-password__content">
    <p class="morganics-password__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 id="PasswordLaunchTitle">{{ section.settings.heading }}</h1>
    <p class="morganics-password__intro">{{ section.settings.intro }}</p>

    <div class="morganics-password__launch-card" aria-label="Launch date">
      <span>{{ section.settings.launch_label }}</span>
      <strong>{{ launch_date }} · {{ launch_time }}</strong>
    </div>

    {% form 'customer', class: 'morganics-password__notify-form' %}
      <input type="hidden" name="contact[tags]" value="password-page-launch-notify">

      {% if form.posted_successfully? %}
        <p class="morganics-password__form-message morganics-password__form-message--success" tabindex="-1" autofocus>
          {{ section.settings.success_message }}
        </p>
      {% endif %}

      {% if form.errors %}
        <div class="morganics-password__form-message morganics-password__form-message--error" tabindex="-1" autofocus>
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <label class="visually-hidden" for="PasswordNotifyEmail">{{ section.settings.email_label }}</label>
      <div class="morganics-password__notify-row">
        <input
          id="PasswordNotifyEmail"
          type="email"
          name="contact[email]"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          placeholder="{{ section.settings.email_placeholder | escape }}"
          required
        >
        <button type="submit">
          <span>{{ section.settings.email_button }}</span>
          <span aria-hidden="true">→</span>
        </button>
      </div>
    {% endform %}

    <ul class="morganics-password__signals" aria-label="Launch promises">
      <li>Premium pantry essentials</li>
      <li>Pakistan-wide COD</li>
      <li>Natural ingredients</li>
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Password launch page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Morganics is almost ready" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Launching Soon" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Premium nuts, dry fruits, herbs, seeds and wellness pantry essentials for Pakistani homes. We are preparing the store for launch." },
    { "type": "text", "id": "launch_label", "label": "Launch label", "default": "Launching" },
    { "type": "text", "id": "launch_date", "label": "Launch date", "default": "10 June" },
    { "type": "text", "id": "launch_time", "label": "Launch time", "default": "11:00 AM" },
    { "type": "text", "id": "email_label", "label": "Email label", "default": "Email address" },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "Enter your email for launch notice" },
    { "type": "text", "id": "email_button", "label": "Email button", "default": "Notify Me" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "You are on the Morganics launch list." },
    { "type": "text", "id": "password_label", "label": "Password access label", "default": "Enter using password" },
    { "type": "text", "id": "password_input_label", "label": "Password input label", "default": "Store password" },
    { "type": "text", "id": "password_placeholder", "label": "Password placeholder", "default": "Password" },
    { "type": "text", "id": "password_button", "label": "Password button", "default": "Enter" }
  ]
}
{% endschema %}
